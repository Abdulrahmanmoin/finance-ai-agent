# --- Google Gemini ---
# Required. Create a key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Chat model. Examples: gemini-2.5-pro, gemini-2.5-flash, gemini-2.0-flash
# Model names are NEVER hardcoded in source — they come from here.
GEMINI_MODEL=gemini-3.1-flash-lite

# Embedding model. Examples: models/text-embedding-004, models/gemini-embedding-001
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# --- RAG over SEC filings ---
FILINGS_TEXT_PATH=data/Nvidia_10K_20240128.txt
FAISS_INDEX_PATH=.faiss_index/nvda_10k
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
RETRIEVAL_K=6

# --- News pipeline ---
NEWS_MAX_ARTICLES=8
NEWS_REQUEST_TIMEOUT=20

# --- Logging ---
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
